#!/usr/bin/env bash
#
# Sets the desktop wallpaper.
#
#   box-theme-wallpaper ~/box/assets/wallpapers/light/blue-grid.png
#   box-theme-wallpaper <light> <dark>
#
# GNOME holds a wallpaper per appearance, so a dark one is used when given.
# macOS holds one picture, so the light one is used and the dark one ignored.

set -euo pipefail

[[ ${1:-} == -h ]] && exec box-help "$0"

light="${1:-}"
dark="${2:-}"

if [[ -z $light ]]; then
  echo "usage: box-theme-wallpaper <light> [dark]" >&2
  exit 1
fi

# Turns a relative path into an absolute one: cd into its directory, ask pwd
# where that is, then put the filename back on the end.
absolute() {
  echo "$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"
}

# ${dark:+"$dark"} expands to nothing when dark is unset, so the loop runs once
# for a light-only call and twice when both were given.
for file in "$light" ${dark:+"$dark"}; do
  if [[ ! -f $file ]]; then
    echo "❌ box: ${file} not found" >&2
    exit 1
  fi
done

light="$(absolute "$light")"
if [[ -n $dark ]]; then
  dark="$(absolute "$dark")"
fi

os="$("${BOX_ROOT:-$HOME/box}/lib/box-detect-os.sh")"

case "$os" in
  macos)
    osascript -e "tell application \"System Events\" to set picture of every desktop to \"${light}\""

    if [[ -n $dark ]]; then
      echo "⚠️ box: macOS holds one wallpaper, so the dark one needs a .heic pair"
    fi
    ;;
  arch | fedora)
    gsettings set org.gnome.desktop.background picture-uri "file://${light}"
    gsettings set org.gnome.desktop.background picture-uri-dark "file://${dark:-$light}"
    gsettings set org.gnome.desktop.background picture-options zoom
    ;;
esac

echo "✅ box: wallpaper set to $(basename "$light")"
