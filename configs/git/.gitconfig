[user]
  name = Emmanuel Etti
  email = emmanueletti@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIOFE+wABBsIiFYZKZPGfQ+vjzhSm58TZydg4dujVcbR8
[core]
	editor = $EDITOR
  commitGraph = true
	pager = delta
	excludesfile = ~/.gitignore_global
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  side-by-side = true
  line-numbers = true
  hyperlinks = true
[diff]
  algorithm = histogram
  colorMoved = default
[merge]
  conflictStyle = zdiff3
[init]
  defaultBranch = main
[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto
  interactive = auto
[push]
  default = current
  autoSetupRemote = true
[pull]
  rebase = true
[commit]
  template = ~/.gitmessage
	# gpgsign = true
[pager]
	branch = false
	diff = true
	log = true
[format]
	pretty = %C(yellow)%h %Creset %s %Cgreen(%ar)
[rebase]
	instructionFormat = %s %Cgreen(%ar)%Creset
	autosquash = true
# [gpg]
# 	format = ssh
# [gpg "ssh"]
# 	program = /opt/1Password/op-ssh-sign
