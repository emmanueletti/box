# Theme
theme = dark:Tomorrow Night,light:Alabaster

# Font
font-size = 11
font-family = "JetBrains Mono"
font-thicken = true
adjust-cell-height = 20%
# Disable programming ligatures (calt drives them; liga as a safety net)
font-feature = -calt
font-feature = -liga

# Cursor
cursor-style = block
cursor-style-blink = false

# Window
window-padding-x = 4
window-padding-y = 4
window-padding-balance = true
window-decoration = false
# window-padding-color = background
window-padding-color = extend

# Shell integration
shell-integration = detect
shell-integration-features = no-cursor

# Scrollback
scrollback-limit = 100000000
mouse-scroll-multiplier="0.5"

# Clipboard
clipboard-read = allow
clipboard-write = allow

# Performance
gtk-single-instance = desktop

# Keybindings
keybind = ctrl+l=clear_screen
keybind = performable:ctrl+c=copy_to_clipboard

keybind = ctrl+d=new_split:right
keybind = ctrl+shift+d=new_split:down

keybind = performable:ctrl+shift+left=goto_split:left
keybind = performable:ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:top
keybind = ctrl+shift+down=goto_split:bottom

